local ESPTab = Window:CreateTab("Enhanced ESP", "eye")

local ESPObjects = {}
local BoxESPObjects = {}
local TracerESPObjects = {}

local PlayerESPEnabled = false
local BoxESPEnabled = false
local TracerESPEnabled = false

local function createPlayerOutlineESP(player)
    local character = player.Character
    if not character then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Outline"
    highlight.FillColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Parent = character
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Billboard"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 200, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.Parent = character
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.TextStrokeTransparency = 0
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.TextScaled = true
    textLabel.Text = player.Name .. " | 100"
    textLabel.Parent = billboard
    
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.HealthChanged:Connect(function(health)
            textLabel.Text = player.Name .. " | " .. math.floor(health)
        end)
    end
    
    table.insert(ESPObjects, {player = player, highlight = highlight, billboard = billboard})
end

local function createBoxESP(player)
    local character = player.Character
    if not character then return end
    
    local box = Instance.new("BoxHandleAdornment")
    box.Name = "ESP_Box"
    box.Size = Vector3.new(4, 6, 2)
    box.Color3 = Color3.fromRGB(255, 255, 255)
    box.AlwaysOnTop = true
    box.Transparency = 0.5
    box.ZIndex = 5
    box.Adornee = character
    box.Parent = character
    
    table.insert(BoxESPObjects, {player = player, box = box})
end

local function createTracerESP(player)
    local character = player.Character
    if not character then return end
    
    local tracer = Instance.new("Beam")
    tracer.Name = "ESP_Tracer"
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
    if not rootPart then return end
    
    local attachment0 = Instance.new("Attachment")
    attachment0.Parent = rootPart
    
    local localRoot = LocalPlayer.Character and (LocalPlayer.Character:FindFirstChild("HumanoidRootPart") or LocalPlayer.Character.PrimaryPart)
    if not localRoot then return end
    
    local attachment1 = Instance.new("Attachment")
    attachment1.Parent = localRoot
    
    tracer.Attachment0 = attachment0
    tracer.Attachment1 = attachment1
    tracer.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255))
    tracer.Transparency = NumberSequence.new(0.5)
    tracer.Parent = character
    
    table.insert(TracerESPObjects, {player = player, tracer = tracer})
end

local function removePlayerESP(player)
    for i, obj in ipairs(ESPObjects) do
        if obj.player == player then
            if obj.highlight then obj.highlight:Destroy() end
            if obj.billboard then obj.billboard:Destroy() end
            table.remove(ESPObjects, i)
            break
        end
    end
    for i, obj in ipairs(BoxESPObjects) do
        if obj.player == player then
            if obj.box then obj.box:Destroy() end
            table.remove(BoxESPObjects, i)
            break
        end
    end
    for i, obj in ipairs(TracerESPObjects) do
        if obj.player == player then
            if obj.tracer then obj.tracer:Destroy() end
            table.remove(TracerESPObjects, i)
            break
        end
    end
end

ESPTab:CreateToggle({
    Name = "Player Outline ESP",
    CurrentValue = false,
    Flag = "OutlineESP",
    Callback = function(Value)
        PlayerESPEnabled = Value
        if Value then
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    createPlayerOutlineESP(player)
                end
            end
        else
            for _, obj in ipairs(ESPObjects) do
                if obj.highlight then obj.highlight:Destroy() end
                if obj.billboard then obj.billboard:Destroy() end
            end
            ESPObjects = {}
