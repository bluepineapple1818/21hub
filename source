ESPTab:CreateSection("World ESP")

local WorldESPEnabled = false
local WorldESPObjects = {}

local function createWorldESP()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj.Anchored and not obj:FindFirstChild("WorldESP_Highlight") then
            local highlight = Instance.new("Highlight")
            highlight.Name = "WorldESP_Highlight"
            highlight.FillColor = Color3.fromRGB(255, 0, 0)
            highlight.OutlineColor = Color3.fromRGB(255, 100, 100)
            highlight.FillTransparency = 0.7
            highlight.Parent = obj
            table.insert(WorldESPObjects, highlight)
        end
    end
end

local function removeWorldESP()
    for _, highlight in ipairs(WorldESPObjects) do
        if highlight then highlight:Destroy() end
    end
    WorldESPObjects = {}
end

ESPTab:CreateToggle({
    Name = "Unanchored Parts ESP",
    CurrentValue = false,
    Flag = "WorldESP",
    Callback = function(Value)
        WorldESPEnabled = Value
        if Value then
            createWorldESP()
            while WorldESPEnabled do
                createWorldESP()
                task.wait(2)
            end
        else
            removeWorldESP()
        end
    end
})

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(character)
        if PlayerESPEnabled then
            createPlayerOutlineESP(player)
        end
        if BoxESPEnabled then
            createBoxESP(player)
        end
        if TracerESPEnabled then
            createTracerESP(player)
        end
    end)
end)

Players.PlayerRemoving:Connect(function(player)
    removePlayerESP(player)
end)

